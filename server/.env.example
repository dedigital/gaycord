NODE_ENV=production
PUBLIC_URL=https://gaycord.onrender.com
MAX_UPLOAD_BYTES=15728640
MAX_BACKUP_BYTES=62914560
PBKDF2_ITERATIONS=310000
REQUIRE_HTTPS=1
# Virgülle ayır: https://gaycord.onrender.com,https://custom-domain.com
TRUSTED_ORIGINS=https://gaycord.onrender.com

# Veriler güncellemede gitmesin diye en iyi seçenek:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require

# Render Disk kullanırsan:
# GAYCORD_DATA_DIR=/var/data/gaycord

# V6.1 güvenlik limitleri
MAX_E2EE_TEXT_BYTES=16384
MAX_E2EE_METADATA_BYTES=32768
MAX_SOCKET_EVENT_BYTES=262144
MAX_STORED_MESSAGE_BYTES=49152
MAX_CHANNEL_MESSAGE_BYTES=2097152
SOCKET_MESSAGE_LIMIT=120
SOCKET_MESSAGE_WINDOW_MS=60000
