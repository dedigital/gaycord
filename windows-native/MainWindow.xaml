<Window x:Class="Gaycord.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gaycord" Height="780" Width="1240" MinHeight="660" MinWidth="1020"
        Icon="Assets/gaycord.ico"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid x:Name="LoginView" Background="{StaticResource BgBrush}">
            <Border Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30" CornerRadius="28" Background="{StaticResource PanelBrush}" BorderBrush="#343C55" BorderThickness="1">
                <StackPanel>
                    <Image Source="Assets/gaycord-logo.png" Width="160" Height="160" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Gaycord" FontSize="42" FontWeight="Black" TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Native Windows istemcisi. Sunucu URL'ini yaz, hesabınla gir." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,22"/>
                    <TextBlock Text="Sunucu URL" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="ServerUrlBox" Text="https://gaycord.onrender.com"/>
                    <TextBlock Text="Kullanıcı adı" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="UsernameBox"/>
                    <TextBlock Text="Görünen ad (kayıt için)" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="DisplayNameBox"/>
                    <TextBlock Text="Şifre" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <PasswordBox x:Name="PasswordBox"/>
                    <DockPanel Margin="0,8,0,0">
                        <Button x:Name="LoginButton" Content="Giriş yap" Click="LoginButton_Click" Background="{StaticResource BrandBrush}" FontWeight="Bold" MinWidth="140"/>
                        <Button x:Name="RegisterButton" Content="Hesap oluştur" Click="RegisterButton_Click" MinWidth="150"/>
                    </DockPanel>
                    <TextBlock x:Name="LoginStatus" Foreground="#FF8EA5" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ShellView" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96"/>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#05060D" BorderBrush="#222840" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True" Margin="10">
                    <StackPanel DockPanel.Dock="Top">
                        <Button ToolTip="Arkadaşlar" Click="HomeButton_Click" Height="62" Padding="0">
                            <Image Source="Assets/icon-64.png" Width="46" Height="46"/>
                        </Button>
                        <Separator Margin="8" Background="#2E3654"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Content="＋" ToolTip="Sunucu oluştur" FontSize="20" Click="CreateServerButton_Click" Height="52"/>
                        <Button Content="⌁" ToolTip="Davet koduyla katıl" FontSize="20" Click="JoinServerButton_Click" Height="52"/>
                    </StackPanel>
                    <ListBox x:Name="ServerList" SelectionChanged="ServerList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1F34" BorderBrush="#303856" BorderThickness="1" CornerRadius="16" Padding="8" Margin="0,4" Width="68">
                                    <TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" FontWeight="Black" FontSize="12"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="#252D48" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="78"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="195"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#252D48" BorderThickness="0,0,0,1" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="SideTitle" Text="Arkadaşlar" FontSize="20" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PresenceText" Grid.Row="1" Text="bağlanıyor" Foreground="#36D993" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="14">
                            <TextBlock x:Name="SectionOneTitle" Text="Kanallar" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="4,8"/>
                            <ListBox x:Name="ChannelList" SelectionChanged="ChannelList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1B2035" CornerRadius="14" Padding="12" BorderBrush="#303856" BorderThickness="1">
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Text="Arkadaşlar" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="4,18,4,8"/>
                            <ListBox x:Name="FriendList" MouseDoubleClick="FriendList_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1B2035" CornerRadius="14" Padding="12" BorderBrush="#303856" BorderThickness="1">
                                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="2" BorderBrush="#252D48" BorderThickness="0,1,0,0" Padding="12">
                        <StackPanel>
                            <TextBox x:Name="ActionBox" Text="" ToolTip="Arkadaş kullanıcı adı / kanal adı / davet kodu"/>
                            <WrapPanel>
                                <Button Content="Arkadaş ekle" Click="AddFriendButton_Click"/>
                                <Button Content="Kanal aç" Click="CreateChannelButton_Click"/>
                                <Button x:Name="DeleteServerButton" Content="Sunucuyu sil" Click="DeleteServerButton_Click" Background="{StaticResource DangerBrush}" Visibility="Collapsed"/>
                                <Button x:Name="LeaveServerButton" Content="Çık" Click="LeaveServerButton_Click" Visibility="Collapsed"/>
                                <Button Content="Yenile" Click="RefreshButton_Click"/>
                            </WrapPanel>
                            <TextBlock x:Name="MeText" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="4,6,4,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="2" Background="#0A0C17">
                <Grid.RowDefinitions>
                    <RowDefinition Height="78"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="92"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#252D48" BorderThickness="0,0,0,1" Padding="18,12" Background="#101426">
                    <DockPanel LastChildFill="True">
                        <StackPanel>
                            <TextBlock x:Name="ChatTitle" Text="Hoş geldin" FontSize="24" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="ChatSubtitle" Text="Bir kanal veya DM seç." Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <WrapPanel DockPanel.Dock="Right">
                            <Button x:Name="CopyInviteButton" Content="Davet kodu" Click="CopyInviteButton_Click"/>
                            <Button x:Name="LiveVoiceButton" Content="🎧 Ses odası" Click="LiveVoiceButton_Click" Background="{StaticResource BrandBrush}" FontWeight="Bold"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>
                <ListBox x:Name="MessageList" Grid.Row="1" Margin="18" MouseDoubleClick="MessageList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#171D31" CornerRadius="16" Padding="13" Margin="0,5" BorderBrush="#2E3654" BorderThickness="1" MaxWidth="820" HorizontalAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="{Binding Header}" Foreground="#A2A8BD" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Hint}" Foreground="#22C7FF" FontSize="12" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border Grid.Row="2" Background="#101426" BorderBrush="#252D48" BorderThickness="0,1,0,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="VoiceMessageButton" Grid.Column="0" Content="🎙 Ses" Click="VoiceMessageButton_Click" MinWidth="88"/>
                        <TextBox x:Name="MessageBox" Grid.Column="1" VerticalContentAlignment="Center" Margin="10,0" KeyDown="MessageBox_KeyDown" TextWrapping="Wrap" AcceptsReturn="True"/>
                        <Button Grid.Column="2" Content="Gönder" Click="SendButton_Click" Background="{StaticResource BrandBrush}" FontWeight="Bold" MinWidth="112"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
