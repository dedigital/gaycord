<Window x:Class="ArkadasOdasi.Native.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arkadaş Odası" Height="760" Width="1180" MinHeight="640" MinWidth="980"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}">
    <Grid>
        <Grid x:Name="LoginView" Background="{StaticResource BgBrush}">
            <Border Width="430" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="28" CornerRadius="24" Background="{StaticResource PanelBrush}" BorderBrush="#2B3248" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Arkadaş Odası" FontSize="32" FontWeight="Black" Margin="0,0,0,6"/>
                    <TextBlock Text="Native Windows istemcisi. Sunucu URL'ini yaz, hesabınla gir." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,22"/>
                    <TextBlock Text="Sunucu URL" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="ServerUrlBox" Text="https://senin-uygulaman.onrender.com"/>
                    <TextBlock Text="Kullanıcı adı" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="UsernameBox"/>
                    <TextBlock Text="Görünen ad (kayıt için)" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <TextBox x:Name="DisplayNameBox"/>
                    <TextBlock Text="Şifre" Foreground="{StaticResource MutedBrush}" FontWeight="Bold"/>
                    <PasswordBox x:Name="PasswordBox"/>
                    <DockPanel Margin="0,8,0,0">
                        <Button x:Name="LoginButton" Content="Giriş yap" Click="LoginButton_Click" Background="{StaticResource BrandBrush}" FontWeight="Bold" MinWidth="130"/>
                        <Button x:Name="RegisterButton" Content="Hesap oluştur" Click="RegisterButton_Click" MinWidth="130"/>
                    </DockPanel>
                    <TextBlock x:Name="LoginStatus" Foreground="#FF7D95" TextWrapping="Wrap" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ShellView" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="82"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Background="#080A11" BorderBrush="#1E2434" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top">
                        <Button Content="🏠" ToolTip="Arkadaşlar" FontSize="18" Click="HomeButton_Click" Height="54"/>
                        <Separator Margin="8" Background="#252B3F"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Bottom">
                        <Button Content="＋" ToolTip="Sunucu oluştur" FontSize="18" Click="CreateServerButton_Click" Height="50"/>
                        <Button Content="⌁" ToolTip="Davet koduyla katıl" FontSize="18" Click="JoinServerButton_Click" Height="50"/>
                    </StackPanel>
                    <ListBox x:Name="ServerList" SelectionChanged="ServerList_SelectionChanged"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="#252B3F" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="155"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#252B3F" BorderThickness="0,0,0,1" Padding="16">
                        <StackPanel>
                            <TextBlock x:Name="SideTitle" Text="Arkadaşlar" FontSize="18" FontWeight="Black"/>
                            <TextBlock x:Name="PresenceText" Text="bağlanıyor" Foreground="#31D68B" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <TextBlock x:Name="SectionOneTitle" Text="Kanallar" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="4,8"/>
                            <ListBox x:Name="ChannelList" SelectionChanged="ChannelList_SelectionChanged"/>
                            <TextBlock Text="Arkadaşlar" Foreground="{StaticResource MutedBrush}" FontWeight="Bold" Margin="4,18,4,8"/>
                            <ListBox x:Name="FriendList" MouseDoubleClick="FriendList_MouseDoubleClick"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="2" BorderBrush="#252B3F" BorderThickness="0,1,0,0" Padding="12">
                        <StackPanel>
                            <TextBox x:Name="ActionBox" Text="" ToolTip="Arkadaş kullanıcı adı / kanal adı / davet kodu"/>
                            <WrapPanel>
                                <Button Content="Arkadaş ekle" Click="AddFriendButton_Click"/>
                                <Button Content="Kanal aç" Click="CreateChannelButton_Click"/>
                                <Button Content="Yenile" Click="RefreshButton_Click"/>
                            </WrapPanel>
                            <TextBlock x:Name="MeText" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="2" Background="#0D101A">
                <Grid.RowDefinitions>
                    <RowDefinition Height="74"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="86"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" BorderBrush="#252B3F" BorderThickness="0,0,0,1" Padding="18,12">
                    <DockPanel LastChildFill="True">
                        <StackPanel>
                            <TextBlock x:Name="ChatTitle" Text="Hoş geldin" FontSize="22" FontWeight="Black"/>
                            <TextBlock x:Name="ChatSubtitle" Text="Bir kanal veya DM seç." Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                        <WrapPanel DockPanel.Dock="Right">
                            <Button x:Name="CopyInviteButton" Content="Davet kodu" Click="CopyInviteButton_Click"/>
                            <Button x:Name="LiveVoiceButton" Content="🎧 Ses odası" Click="LiveVoiceButton_Click"/>
                        </WrapPanel>
                    </DockPanel>
                </Border>
                <ListBox x:Name="MessageList" Grid.Row="1" Margin="18" MouseDoubleClick="MessageList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#171C2B" CornerRadius="14" Padding="12" Margin="0,4" BorderBrush="#252B3F" BorderThickness="1" MaxWidth="760">
                                <StackPanel>
                                    <TextBlock Text="{Binding Header}" Foreground="#9CA8BD" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding Hint}" Foreground="#22C7FF" FontSize="12" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border Grid.Row="2" Background="#111522" BorderBrush="#252B3F" BorderThickness="0,1,0,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="VoiceMessageButton" Grid.Column="0" Content="🎙 Ses" Click="VoiceMessageButton_Click" MinWidth="86"/>
                        <TextBox x:Name="MessageBox" Grid.Column="1" VerticalContentAlignment="Center" Margin="10,0" KeyDown="MessageBox_KeyDown"/>
                        <Button Grid.Column="2" Content="Gönder" Click="SendButton_Click" Background="{StaticResource BrandBrush}" FontWeight="Bold" MinWidth="110"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
