<Application x:Class="Gaycord.Native.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#080912"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#15182A"/>
        <SolidColorBrush x:Key="Panel2Brush" Color="#202640"/>
        <SolidColorBrush x:Key="Panel3Brush" Color="#272D49"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F6F7FF"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A2A8BD"/>
        <SolidColorBrush x:Key="BrandBrush" Color="#8B5CFF"/>
        <SolidColorBrush x:Key="Brand2Brush" Color="#22C7FF"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF5577"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F6F7FF"/>
            <Setter Property="Background" Value="#242A45"/>
            <Setter Property="BorderBrush" Value="#394160"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F6F7FF"/>
            <Setter Property="Background" Value="#1C2137"/>
            <Setter Property="BorderBrush" Value="#394160"/>
            <Setter Property="CaretBrush" Value="#F6F7FF"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="#F6F7FF"/>
            <Setter Property="Background" Value="#1C2137"/>
            <Setter Property="BorderBrush" Value="#394160"/>
            <Setter Property="CaretBrush" Value="#F6F7FF"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#F6F7FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Application.Resources>
</Application>
