<Application x:Class="ArkadasOdasi.Native.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0B0D14"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#151A29"/>
        <SolidColorBrush x:Key="Panel2Brush" Color="#20263A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9CA8BD"/>
        <SolidColorBrush x:Key="BrandBrush" Color="#6D5DFC"/>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB"/>
            <Setter Property="Background" Value="#252B3F"/>
            <Setter Property="BorderBrush" Value="#343C55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F4F7FB"/>
            <Setter Property="Background" Value="#1C2234"/>
            <Setter Property="BorderBrush" Value="#343C55"/>
            <Setter Property="CaretBrush" Value="#F4F7FB"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="#F4F7FB"/>
            <Setter Property="Background" Value="#1C2234"/>
            <Setter Property="BorderBrush" Value="#343C55"/>
            <Setter Property="CaretBrush" Value="#F4F7FB"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#F4F7FB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Application.Resources>
</Application>
